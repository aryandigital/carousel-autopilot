# ============================================
# CAROUSEL AUTOMATION â€” Environment Variables
# ============================================
# Copy this file to .env and fill in your keys

# Google AI Studio API Key (free)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
# Optional: comma-separated extra keys for image generation rotation
# GOOGLE_IMAGE_API_KEYS=key1,key2,key3
# Optional: comma-separated image models (defaults are set in code)
# GOOGLE_IMAGE_MODELS=gemini-2.5-flash-image,gemini-3.1-flash-image-preview,nano-banana-pro-preview

# LinkedIn API Credentials (free â€” register at developer.linkedin.com)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Schedule (24h format, IST timezone)
CRON_HOUR=9
CRON_MINUTE=0
# Optional: run multiple times/day (for 3 carousels/day use 9,13,18)
# CRON_HOURS=9,13,18

# Server
PORT=3000
